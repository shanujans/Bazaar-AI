# Copy this file to .env and fill in real values.
# .env is already git-ignored — never commit real secrets.

# --- Required ---
# Fireworks Serverless API key (used for both the edge and heavy tiers).
FIREWORKS_API_KEY=fw_your_key_here

# --- Model endpoints (override to point at self-hosted vLLM / mock_servers.py) ---
EDGE_ENDPOINT_URL=https://api.fireworks.ai/inference/v1/chat/completions
HEAVY_ENDPOINT_URL=https://api.fireworks.ai/inference/v1/chat/completions

# --- Backend behavior ---
# If true, an unreachable model endpoint returns a clearly-labeled simulated
# reply instead of a 500, so a live demo never hard-fails mid-show.
ALLOW_SIMULATED_FALLBACK=true

EDGE_TIMEOUT_SECONDS=15
HEAVY_TIMEOUT_SECONDS=60
PORT=8080

# --- Dashboard (dashboard.py) ---
# Where the Streamlit dashboard looks for the backend. Also settable live
# from the dashboard's sidebar.
API_BASE_URL=http://localhost:8080

# --- Twilio (needed only if you're testing /api/whatsapp/ against real Twilio,
# not required for the mock/local demo path) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
